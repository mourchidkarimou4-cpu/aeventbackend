# ═══════════════════════════════════════════════════════════════════
# Backend Django Configuration
# Copier ce fichier en .env et remplir avec vos vraies valeurs
# ⚠️ IMPORTANT: JAMAIS commiter le fichier .env réel en production !
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────────────────────────
DEBUG=False
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-please
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ─────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────
# Option 1: DATABASE_URL (Recommended for production/render.com)
DATABASE_URL=postgresql://user:password@localhost:5432/aevents_db

# Option 2: Individual DB settings (Development)
DB_NAME=aevents_db
DB_USER=aevents_user
DB_PASSWORD=very_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────────────────
# CLOUDINARY (Image Storage)
# Get these from https://cloudinary.com/console
# ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────────────────────────
# CORS & Security
# ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourdomain.com

# ====================================
# Optional Settings
# ====================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
